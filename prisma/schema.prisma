// Prisma schema — PostgreSQL for production (Vercel serverless).
// Local: set DATABASE_URL to a Postgres instance (Docker, Supabase, Neon, etc.).
// Vercel: use a pooled connection string from your provider (not SQLite / not file: URLs).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
 
model Job {
  id          String        @id @default(cuid())
  title       String
  company     String
  location    String
  salary      String
  type        String
  description String
  published   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  applications Application[]
}

model Application {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  email       String
  phone       String
  resumeLink  String?
  coverLetter String?
  createdAt   DateTime @default(now())
}
